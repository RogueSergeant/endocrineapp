# Firebase config is loaded via the native config files
# (google-services.json on Android, GoogleService-Info.plist on iOS).
# This file is for app-level toggles only.

EXPO_PUBLIC_USE_FIRESTORE_EMULATOR=0
EXPO_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1
EXPO_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
EXPO_PUBLIC_AUTH_EMULATOR_URL=http://127.0.0.1:9099
